# ==========================================
# Islamic AI Backend - Environment Config
# ==========================================

# Port Configuration
PORT=3000

# AI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Quran API Configuration
# Using free public Quran API
QURAN_API_URL=https://api.alquran.cloud

# CORS Configuration
# For local network development with Expo mobile app
# Your computer IP address on WiFi network
# Example: http://192.168.1.100
FRONTEND_URL=http://192.168.1.100:19000

# Environment
NODE_ENV=development

# Hadith API Configuration (optional)
HADITH_API_URL=https://hadithapi.com

# Scholar AI Model Configuration
# Will be used when connecting to external AI service
AI_MODEL=gpt-3.5-turbo
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2000
